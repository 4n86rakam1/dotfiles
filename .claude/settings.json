{
  "permissions": {
    "allow": [
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git blame*)",
      "Bash(git stash list*)",
      "Bash(git tag*)",
      "Bash(git describe*)",
      "Bash(git grep*)",
      "Bash(git ls-files*)",
      "Bash(git shortlog*)",
      "WebSearch",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh repo view*)",
      "Bash(gh release list*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh auth status*)",
      "Bash(gh api *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -r /*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(> /etc/*)",
      "Bash(chmod -R 777*)",
      "Bash(sudo rm*)",
      "Bash(sudo chmod*)",
      "Bash(sudo chown*)",
      "Bash(sudo dd*)",
      "Bash(sudo mkfs*)",
      "Bash(cat ~/.ssh*)",
      "Bash(cat ~/.aws*)",
      "Bash(cat ~/.gnupg*)",
      "Bash(cat ~/.config/gcloud*)",
      "Bash(history -c*)",
      "Bash(history -d*)",
      "Bash(shred*)",
      "Bash(wipefs*)"
    ]
  },
  "model": "claude-opus-4-7",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.dotfiles/.claude/hooks/gh_api_readonly.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.dotfiles/.claude/hooks/formatter.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.dotfiles/.claude/hooks/session_title.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.dotfiles/.claude/hooks/claude_notify.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "crit@crit": true
  },
  "extraKnownMarketplaces": {
    "crit": {
      "source": {
        "source": "github",
        "repo": "tomasz-tomczyk/crit"
      }
    }
  },
  "language": "Japanese",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "dark",
  "editorMode": "normal",
  "preferredNotifChannel": "auto",
  "autoCompactEnabled": true,
  "agentPushNotifEnabled": false
}
